        -- Hide all tabs
        for _, frame in ipairs(tabFrames) do
            frame.Visible = false
        end
        -- Show selected tab
        if tabFrames[i] then
            tabFrames[i].Visible = true
            ContentScroll.CanvasPosition = Vector2.new(0, 0) -- Reset scroll position
        end
        currentTab = i
        -- Update button colors
        for j, btn in ipairs(TabScroll:GetChildren()) do
            if btn:IsA("TextButton") then
                btn.BackgroundColor3 = j == i and Color3.fromRGB(200, 0, 0) or Color3.fromRGB(50, 50, 50)
            end
        end
    end)
    
    if i == 1 then
        TabBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    end
end

-- Helper function to add labels with RGB effect
local function AddLabel(text, isRGB)
    local Label = Instance.new("TextLabel")
    Label.Name = "Label"
    Label.Size = UDim2.new(0.95, 0, 0, 30)
    Label.Position = UDim2.new(0.025, 0, 0, 0)
    Label.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    Label.TextColor3 = isRGB and Color3.fromRGB(255, 100, 100) or Color3.fromRGB(200, 200, 200)
    Label.TextSize = 14
    Label.Font = Enum.Font.Gotham
    Label.Text = text
    Label.TextWrapped = true
    Label.BorderSizePixel = 1
    Label.BorderColor3 = Color3.fromRGB(100, 100, 100)
    Label.Parent = ContentScroll
    
    if isRGB then
        task.spawn(function()
            while Label.Parent do
                Label.TextColor3 = Color3.fromHSV(tick() * 0.3 % 1, 0.8, 1)
                task.wait(0.02)
            end
        end)
    end
    
    return Label
end

